{
  "name": "solid-snake-tui",
  "version": "0.1.3",
  "description": "Snake in the terminal built with OpenTUI and Solid",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "solid-snake-tui": "./bin/solid-snake-tui.js"
  },
  "files": [
    "bin",
    "dist",
    "public",
    "README.md"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "dev": "bun run --watch src/index.tsx",
    "start": "bun run src/index.tsx",
    "prepack": "bun run build"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@opentui/core": "^0.1.91",
    "@opentui/solid": "^0.1.91",
    "babel-preset-solid": "1.9.9",
    "solid-js": "1.9.9"
  }
}
